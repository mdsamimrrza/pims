PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/pims?retryWrites=true&w=majority&appName=pims
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ADMIN_SETUP_TOKEN=change_this_setup_token
EMAIL_MODE=file
EMAIL_OUTBOX_DIR=outbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=PIMS <your-gmail-address@gmail.com>
PHARMACY_NOTIFICATION_EMAIL=pharmacy@pims.local
ENABLE_BACKGROUND_JOBS=true
LOW_STOCK_JOB_INTERVAL_MS=21600000
EXPIRY_JOB_INTERVAL_MS=86400000
